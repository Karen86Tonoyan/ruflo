# =============================================================================
# Chat UI + MCP Bridge — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env with real keys.
# =============================================================================

# --- Brand ---
BRAND_NAME=RuFlo
BRAND_DESCRIPTION=Enterprise AI Agent Orchestration Platform
PUBLIC_ORIGIN=http://localhost:3000

# --- AI Provider API Keys (at least one required) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=

# --- Local / OpenAI-compatible providers ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_OPENAI_BASE_URL=http://localhost:8000/v1
LOCAL_OPENAI_API_KEY=

# --- Provider routing ---
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_MODEL=
LLM_PROVIDER_FALLBACKS=openrouter,openai,anthropic,google,ollama
LLM_ROUTING_MODE=balanced
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2

# --- MongoDB ---
MONGODB_DB_NAME=chat-db

# --- Google OIDC Auth (optional — leave empty to disable) ---
OPENID_PROVIDER_URL=
OPENID_CLIENT_ID=
OPENID_CLIENT_SECRET=
OPENID_SCOPES=openid profile email
OPENID_NAME_CLAIM=name
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Backend Service URLs (for your custom MCP tools) ---
SEARCH_API_URL=
RESEARCH_API_URL=

# =============================================================================
# TOOL GROUPS — Enable/disable categories of MCP tools
# =============================================================================
# Tools are organized into groups. Enable only the groups you need.
# The AI can call `guidance` to learn what each group offers.
#
# Default-on groups (set to "false" to disable):
MCP_GROUP_INTELLIGENCE=true    # ruvector: routing, vector memory, learning (10 tools)
MCP_GROUP_AGENTS=true          # ruflo: agents, swarms, tasks, workflows (50 tools)
MCP_GROUP_MEMORY=true          # ruflo: memory, AgentDB, embeddings (25 tools)
MCP_GROUP_DEVTOOLS=true        # ruflo: hooks, analysis, performance, GitHub (60 tools)
#
# Opt-in groups (set to "true" to enable):
MCP_GROUP_SECURITY=false       # ruflo: AI defence, PII detection, claims (25 tools)
MCP_GROUP_BROWSER=false        # ruflo: headless browser automation (23 tools)
MCP_GROUP_NEURAL=false         # ruflo: neural networks, DAA agents (20 tools)
MCP_GROUP_AGENTIC_FLOW=false   # agentic-flow@alpha: 66+ agents, boosted editing (15 tools)
MCP_GROUP_CLAUDE_CODE=false    # Claude Code MCP server (requires ANTHROPIC_API_KEY)
MCP_GROUP_GEMINI=false         # Gemini MCP server (uses GOOGLE_API_KEY)
MCP_GROUP_CODEX=false          # OpenAI Codex MCP (uses OPENAI_API_KEY)

# --- Optional external MCP servers from Karen86Tonoyan GitHub / npm-compatible packages ---
MCP_GROUP_FORGE=false          # Forge MCP: GPU kernel optimization, CUDA/Triton workflows
MCP_GROUP_BLUEPRINT=false      # Blueprint MCP: real-browser automation across Chrome/Firefox/Safari
MCP_GROUP_CUSTOM=false         # Generic custom MCP server configured below

# Forge MCP server command. Defaults assume npm package/bin compatibility.
MCP_FORGE_COMMAND=npx
MCP_FORGE_ARGS=-y @rightnow/forge-mcp-server

# Blueprint MCP server command. Defaults assume npm package/bin compatibility.
MCP_BLUEPRINT_COMMAND=npx
MCP_BLUEPRINT_ARGS=-y @railsblueprint/blueprint-mcp

# Custom MCP server escape hatch for community/user choice.
# Example:
# MCP_CUSTOM_NAME=my-tools
# MCP_CUSTOM_COMMAND=npx
# MCP_CUSTOM_ARGS=-y my-mcp-server --stdio
MCP_CUSTOM_NAME=custom
MCP_CUSTOM_COMMAND=
MCP_CUSTOM_ARGS=

# --- GCP Deployment (used by scripts/deploy.sh) ---
GCP_PROJECT_ID=
GCP_REGION=us-central1
